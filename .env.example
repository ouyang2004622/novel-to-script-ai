NEXT_PUBLIC_APP_NAME="AI 小说转剧本工具"

# DeepSeek uses an OpenAI-compatible API format.
# Keep real secrets in .env.local and never commit them.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# MOCK_AI=true uses local mock data and does not require an API key.
# MOCK_AI=false calls DeepSeek when DEEPSEEK_API_KEY is configured.
MOCK_AI=true
